---
import { Image } from "astro:assets";
import { getLangFromUrl } from "../i18n/utils";
import { Icon } from "astro-icon/components";
import { AUTHOR, SOCIALS } from "../config";
import avatarImage from "../assets/profile.jpg";
import { getRelativeLocaleUrl } from "astro:i18n";

const lang = getLangFromUrl(Astro.url);
const role = AUTHOR.role[lang as keyof typeof AUTHOR.role] ?? AUTHOR.role.en;
const bio = AUTHOR.bio[lang as keyof typeof AUTHOR.bio] ?? AUTHOR.bio.en;
---

<div class="profile-card">
    <div class="avatar">
        <Image
            src={avatarImage}
            alt={`${AUTHOR.name} profile picture`}
            width={300}
            height={300}
            loading="eager"
        />
    </div>

    <div class="info">
        <h2>{AUTHOR.name}</h2>
        <span class="role">{role}</span>
        <p class="bio">{bio}</p>
    </div>

    <div class="socials">
        {
            SOCIALS.map((social) => {
                const href =
                    social.label === "RSS" ? getRelativeLocaleUrl(lang, "rss.xml") : social.href;

                return (
                    <a
                        href={href}
                        target="_blank"
                        rel="noopener noreferrer"
                        aria-label={social.label}
                    >
                        <Icon name={social.icon} />
                    </a>
                );
            })
        }
    </div>
</div>

<style>
    .profile-card {
        display: flex;
        flex-direction: column;
        align-items: center;
        text-align: center;
        padding: 0;
    }

    .avatar {
        width: 300px;
        height: 300px;
        border-radius: 50%;
        overflow: hidden;
        margin-bottom: 1.5rem;
        border: 1px solid var(--accent);
    }

    .avatar img {
        width: 100%;
        height: 100%;
        object-fit: cover;
    }

    .info h2 {
        font-size: 1.8rem;
        margin-bottom: 0.2rem;
        color: #ffffff;
    }

    .role {
        display: block;
        font-size: 0.9rem;
        color: var(--accent);
        font-weight: 600;
        margin-bottom: 1rem;
    }

    .bio {
        font-size: 0.95rem;
        line-height: 1.6;
        color: rgba(218, 234, 255, 0.8);
        margin-bottom: 1.5rem;
        word-break: break-word;
        overflow-wrap: break-word;
    }

    .socials {
        display: flex;
        flex-wrap: wrap;
        gap: 1rem;
        justify-content: center;
    }

    .socials a {
        display: flex;
        flex-wrap: wrap;
        align-items: center;
        justify-content: center;
        width: 40px;
        height: 40px;
        border-radius: 50%;
        background: rgba(218, 234, 255, 0.05);
        color: var(--light);
        font-size: 1.2rem;
        transition: all var(--transition-speed) ease;
    }

    .socials a:hover {
        background: var(--accent);
        color: #ffffff;
        transform: translateY(-2px);
    }

    @media (max-width: 859px) {
        .avatar {
            display: none;
        }
    }
</style>
