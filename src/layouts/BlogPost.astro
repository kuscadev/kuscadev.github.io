---
import type { CollectionEntry } from 'astro:content';
import type { MarkdownHeading } from 'astro';
import BaseLayout from './BaseLayout.astro';
import { useTranslations } from '../i18n/utils';
import { getLangFromUrl } from '../i18n/utils';
import { getRelativeLocaleUrl } from 'astro:i18n';

type Props = CollectionEntry<'blog'>['data'] & {
	headings?: MarkdownHeading[];
};

const { title, description, pubDate, updatedDate, tags, headings = [] } = Astro.props;
const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

const tocHeadings = headings.filter((h: MarkdownHeading) => h.depth === 2 || h.depth === 3);
---

<BaseLayout title={title} description={description}>
	<div class="post-layout">
		<article class="blog-post">
			<header>
				<h1>{title}</h1>
				<div class="meta">
					<span>
						{t('post.publishedOn')} <time datetime={pubDate.toISOString()}>
							{pubDate.toLocaleDateString(lang, {
								year: 'numeric',
								month: 'long',
								day: 'numeric',
							})}
						</time>
					</span>
					{
						updatedDate && (
							<span class="updated">
								{t('post.updatedOn')} <time datetime={updatedDate.toISOString()}>
									{updatedDate.toLocaleDateString(lang, {
										year: 'numeric',
										month: 'long',
										day: 'numeric',
									})}
								</time>
							</span>
						)
					}
				</div>
				{
					tags && tags.length > 0 && (
						<div class="tags">
							{tags.map((tag: string) => (
								<a href={getRelativeLocaleUrl(lang, `tags/${tag}`)} class="tag">#{tag}</a>
							))}
						</div>
					)
				}
			</header>
			<div class="content">
				<slot />
			</div>

		</article>

		{tocHeadings.length > 0 && (
			<aside class="toc-sidebar">
				<nav class="toc">
					<p class="toc-title">{t('toc.title')}</p>
					<ul>
						{tocHeadings.map((heading: MarkdownHeading) => (
							<li class={`toc-item depth-${heading.depth}`}>
								<a href={`#${heading.slug}`}>{heading.text}</a>
							</li>
						))}
					</ul>
				</nav>
			</aside>
		)}
	</div>
</BaseLayout>

<style>
	/* Layout */
	.post-layout {
		display: grid;
		grid-template-columns: minmax(0, 1fr);
		gap: 3rem;
		align-items: start;
	}

	.blog-post {
		min-width: 0;
	}

	@media (min-width: 860px) {
		.post-layout {
			grid-template-columns: minmax(0, 3fr) minmax(0, 1fr);
			gap: 4rem;
		}
		.toc-sidebar {
			position: sticky;
			top: 2rem;
			align-self: start;
		}
	}

	/* Article header */
	.blog-post header {
		margin-bottom: 3rem;
		text-align: center;
	}

	.blog-post h1 {
		font-size: clamp(1.6rem, 4.5vw, 2.5rem);
		margin-bottom: 1rem;
		margin-top: 0;
	}

	.meta {
		font-size: 0.9rem;
		color: rgba(218, 234, 255, 0.6);
		display: flex;
		flex-wrap: wrap;
		justify-content: center;
		gap: 0.5rem 1.5rem;
		margin-bottom: 1rem;
	}

	.tags {
		display: flex;
		flex-wrap: wrap;
		justify-content: center;
		gap: 0.5rem;
	}

	.tag {
		font-size: 0.85rem;
		color: var(--light);
		background-color: rgba(79, 165, 216, 0.08);
		border: 1px solid rgba(79, 165, 216, 0.2);
		padding: 0.2rem 0.65rem;
		border-radius: 1rem;
		transition: all var(--transition-speed) ease;
		text-decoration: none;
	}

	.tag:hover {
		background-color: var(--accent);
		border-color: var(--accent);
		color: #ffffff;
		transform: translateY(-1px);
	}

	/* Content */
	.content {
		line-height: 1.8;
		word-break: break-word;
		overflow-wrap: break-word;
	}

	.content :global(h2) {
		margin-top: 3rem;
		margin-bottom: 1.5rem;
	}

	.content :global(h3) {
		margin-top: 2rem;
		margin-bottom: 1rem;
	}

	/* ToC sidebar */
	.toc-sidebar {
		display: none;
	}

	@media (min-width: 860px) {
		.toc-sidebar {
			display: block;
		}
	}

	.toc {
		padding-top: 0.25rem;
	}

	.toc-title {
		font-size: 0.75rem;
		font-weight: 700;
		letter-spacing: 0.1em;
		text-transform: uppercase;
		color: var(--accent);
		margin-bottom: 0.75rem;
		padding-bottom: 0.5rem;
		border-bottom: 1px solid rgba(79, 165, 216, 0.15);
	}

	.toc ul {
		list-style: none;
		padding: 0;
		margin: 0;
	}

	.toc-item {
		margin-bottom: 0;
	}

	.toc-item a {
		display: block;
		font-size: 0.85rem;
		color: rgba(218, 234, 255, 0.55);
		text-decoration: none;
		padding: 0.3rem 0;
		line-height: 1.4;
		border-left: 2px solid transparent;
		padding-left: 0.75rem;
		transition: all var(--transition-speed) ease;
	}

	.toc-item a:hover {
		color: var(--light);
		border-left-color: var(--accent);
	}

	.toc-item.depth-3 a {
		padding-left: 1.5rem;
		font-size: 0.8rem;
		color: rgba(218, 234, 255, 0.4);
	}

	.toc-item.depth-3 a:hover {
		color: rgba(218, 234, 255, 0.8);
	}

	.toc-item a.active {
		color: var(--light);
		border-left-color: var(--accent);
		font-weight: 600;
	}

	.toc-item.depth-3 a.active {
		color: rgba(218, 234, 255, 0.85);
	}
</style>

<script>
	const headings = Array.from(
		document.querySelectorAll<HTMLElement>('.content h2[id], .content h3[id]')
	);
	const tocLinks = Array.from(
		document.querySelectorAll<HTMLAnchorElement>('.toc-item a')
	);

	if (headings.length && tocLinks.length) {
		function updateActive() {
			const scrollY = window.scrollY + 120;

			let activeId = headings[0].id;
			for (const heading of headings) {
				if (heading.offsetTop <= scrollY) {
					activeId = heading.id;
				}
			}

			tocLinks.forEach((link) => {
				link.classList.toggle('active', link.getAttribute('href') === `#${activeId}`);
			});
		}

		window.addEventListener('scroll', updateActive, { passive: true });
		updateActive();
	}

	// Copy Code Button Logic
	const codeBlocks = Array.from(document.querySelectorAll('pre'));

	for (const codeBlock of codeBlocks) {
		const wrapper = document.createElement('div');
		wrapper.style.position = 'relative';

		const copyButton = document.createElement('button');
		copyButton.className = 'copy-button';
		copyButton.type = 'button';
		copyButton.ariaLabel = 'Copy code to clipboard';
		copyButton.innerHTML = '<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="9" y="9" width="13" height="13" rx="2" ry="2"></rect><path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"></path></svg>';

		codeBlock.appendChild(copyButton);

		copyButton.addEventListener('click', async () => {
			const code = codeBlock.querySelector('code');
			const text = code ? code.innerText : codeBlock.innerText;

			try {
				await navigator.clipboard.writeText(text);
				copyButton.classList.add('copied');
				copyButton.innerHTML = '<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"></polyline></svg>';

				setTimeout(() => {
					copyButton.classList.remove('copied');
					copyButton.innerHTML = '<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="9" y="9" width="13" height="13" rx="2" ry="2"></rect><path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"></path></svg>';
				}, 2000);
			} catch (err) {
				console.error('Failed to copy text: ', err);
			}
		});
	}
</script>
